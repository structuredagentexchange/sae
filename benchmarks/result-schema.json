{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://structuredagentexchange.org/schema/benchmarks/result-schema.json",
  "title": "SAE Benchmark Result",
  "type": "object",
  "required": ["benchmark_version", "task_id", "lane", "metrics", "notes"],
  "properties": {
    "benchmark_version": { "type": "string" },
    "task_id": { "type": "string" },
    "lane": {
      "type": "string",
      "enum": ["plain_a2a", "sae_over_a2a", "compiler_shaped_sae_over_a2a"]
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "score"],
        "properties": {
          "id": { "type": "string" },
          "score": { "type": "number" },
          "note": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
